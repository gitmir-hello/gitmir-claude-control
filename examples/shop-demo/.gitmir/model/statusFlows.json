[
  {
    "id": "sfw-order",
    "name": "Жизненный цикл заказа",
    "entityId": "ent-order",
    "fieldName": "status",
    "moduleId": "mod-orders",
    "description": "От оформления до доставки, с отменой и возвратом.",
    "states": [
      {
        "key": "draft",
        "name": "черновик",
        "ownerRole": "customer"
      },
      {
        "key": "placed",
        "name": "оформлен",
        "ownerRole": "customer"
      },
      {
        "key": "paid",
        "name": "оплачен",
        "ownerRole": "system"
      },
      {
        "key": "packed",
        "name": "собран",
        "ownerRole": "warehouse"
      },
      {
        "key": "shipped",
        "name": "отгружен",
        "ownerRole": "warehouse"
      },
      {
        "key": "delivered",
        "name": "доставлен",
        "ownerRole": "system"
      },
      {
        "key": "cancelled",
        "name": "отменён"
      },
      {
        "key": "refunded",
        "name": "возврат"
      }
    ],
    "transitions": [
      {
        "from": "draft",
        "to": "placed",
        "byRole": "customer",
        "condition": "checkout",
        "effects": [
          {
            "kind": "create",
            "entityId": "ent-order-item",
            "description": "создаёт позиции"
          },
          {
            "kind": "update",
            "entityId": "ent-inventory",
            "fieldName": "reserved",
            "description": "резерв склада"
          },
          {
            "kind": "recalculate",
            "entityId": "ent-order",
            "fieldName": "total",
            "description": "сумма заказа"
          }
        ]
      },
      {
        "from": "placed",
        "to": "paid",
        "byRole": "customer",
        "condition": "платёж списан",
        "effects": [
          {
            "kind": "create",
            "entityId": "ent-payment",
            "description": "платёж charge"
          },
          {
            "kind": "notify",
            "description": "письмо «оплачено»"
          }
        ]
      },
      {
        "from": "placed",
        "to": "cancelled",
        "byRole": "customer",
        "condition": "до оплаты",
        "effects": [
          {
            "kind": "update",
            "entityId": "ent-inventory",
            "fieldName": "reserved",
            "description": "снять резерв"
          }
        ]
      },
      {
        "from": "paid",
        "to": "packed",
        "byRole": "warehouse",
        "condition": "товар собран",
        "effects": [
          {
            "kind": "update",
            "entityId": "ent-inventory",
            "fieldName": "available",
            "description": "списать со склада"
          }
        ]
      },
      {
        "from": "packed",
        "to": "shipped",
        "byRole": "warehouse",
        "condition": "передан курьеру",
        "effects": [
          {
            "kind": "create",
            "entityId": "ent-shipment",
            "description": "создать отгрузку"
          },
          {
            "kind": "notify",
            "description": "трек-номер покупателю"
          }
        ]
      },
      {
        "from": "shipped",
        "to": "delivered",
        "byRole": "system",
        "condition": "курьер доставил",
        "effects": [
          {
            "kind": "notify",
            "description": "письмо «доставлено»"
          }
        ]
      },
      {
        "from": "paid",
        "to": "refunded",
        "byRole": "support",
        "condition": "возврат одобрен",
        "effects": [
          {
            "kind": "create",
            "entityId": "ent-payment",
            "description": "платёж refund"
          },
          {
            "kind": "update",
            "entityId": "ent-inventory",
            "fieldName": "available",
            "description": "вернуть остаток"
          },
          {
            "kind": "notify",
            "description": "письмо «возврат»"
          }
        ]
      }
    ]
  },
  {
    "id": "sfw-payment",
    "name": "Статус платежа",
    "entityId": "ent-payment",
    "fieldName": "status",
    "moduleId": "mod-payments",
    "states": [
      {
        "key": "pending",
        "name": "ожидает"
      },
      {
        "key": "captured",
        "name": "проведён"
      },
      {
        "key": "failed",
        "name": "ошибка"
      },
      {
        "key": "refunded",
        "name": "возвращён"
      }
    ],
    "transitions": [
      {
        "from": "pending",
        "to": "captured",
        "condition": "успех",
        "effects": []
      },
      {
        "from": "pending",
        "to": "failed",
        "condition": "отказ банка",
        "effects": []
      },
      {
        "from": "captured",
        "to": "refunded",
        "byRole": "support",
        "condition": "возврат",
        "effects": []
      }
    ]
  }
]